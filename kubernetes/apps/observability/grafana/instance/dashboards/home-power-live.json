    {
      "type": "row",
      "title": "Per-Circuit Breakdown",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Current Power by Circuit",
      "description": "Live power draw per monitored circuit",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: \"iotawatt\")\n    |> range(start: -2m)\n    |> filter(fn: (r) => (r._measurement == \"Tesla\" or r._measurement == \"AirConditioner\" or r._measurement == \"Pool\" or r._measurement == \"Server\" or r._measurement == \"LightsGPO\" or r._measurement == \"Kitchen\" or r._measurement == \"Laundry\") and r.unit == \"Watts\")\n    |> last()\n    |> map(fn: (r) => ({_time: r._time, _value: r._value, _field: r._measurement}))\n    |> group(columns: [\"_field\"])"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "B",
          "query": "from(bucket: \"homeassistant\")\n    |> range(start: -24h)\n    |> filter(fn: (r) => r._measurement == \"W\" and r._field == \"value\" and (\n        r.entity_id == \"coffee_power\"\n        or r.entity_id == \"dishwasher_switch_power\"\n        or r.entity_id == \"switch_washing_machine_power\"\n        or r.entity_id == \"dryer_switch_power\"\n    ))\n    |> last()\n    |> map(fn: (r) => ({_time: r._time, _value: r._value, _field:\n        if r.entity_id == \"coffee_power\" then \"Coffee\"\n        else if r.entity_id == \"dishwasher_switch_power\" then \"Dishwasher\"\n        else if r.entity_id == \"switch_washing_machine_power\" then \"Washing Machine\"\n        else \"Dryer\"\n    }))\n    |> group(columns: [\"_field\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 3000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "sizing": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
