          "refId": "A",
          "query": "from(bucket: \"iotawatt\")\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => (r._measurement == \"Tesla\" or r._measurement == \"AirConditioner\" or r._measurement == \"Pool\" or r._measurement == \"Server\" or r._measurement == \"LightsGPO\" or r._measurement == \"Kitchen\" or r._measurement == \"Laundry\") and r.unit == \"Watts\")\n    |> aggregateWindow(every: 30s, fn: mean, createEmpty: false)\n    |> map(fn: (r) => ({_time: r._time, _value: r._value, _field: r._measurement}))\n    |> group(columns: [\"_field\"])"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "B",
          "query": "from(bucket: \"homeassistant\")\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => r._measurement == \"W\" and r._field == \"value\" and (\n        r.entity_id == \"coffee_power\"\n        or r.entity_id == \"dishwasher_switch_power\"\n        or r.entity_id == \"switch_washing_machine_power\"\n        or r.entity_id == \"dryer_switch_power\"\n    ))\n    |> aggregateWindow(every: 30s, fn: mean, createEmpty: false)\n    |> map(fn: (r) => ({_time: r._time, _value: r._value, _field:\n        if r.entity_id == \"coffee_power\" then \"Coffee\"\n        else if r.entity_id == \"dishwasher_switch_power\" then \"Dishwasher\"\n        else if r.entity_id == \"switch_washing_machine_power\" then \"Washing Machine\"\n        else \"Dryer\"\n    }))\n    |> group(columns: [\"_field\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 1,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "row",
      "title": "Phase Balance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "Phase A",
      "description": "Consumption on Phase A (Grid_A + Solar_A)",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: \"iotawatt\")\n    |> range(start: -2m)\n    |> filter(fn: (r) => (r._measurement == \"Grid_A\" or r._measurement == \"Solar_A\") and r.unit == \"Watts\")\n    |> last()\n    |> group()\n    |> sum()\n    |> keep(columns: [\"_value\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "max": 7500,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      }
    },
    {
      "type": "gauge",
      "title": "Phase B",
      "description": "Consumption on Phase B (Grid_B + Solar_B)",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 26
      },
