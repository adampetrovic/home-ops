          "refId": "A",
          "query": "from(bucket: \"iotawatt\")\n    |> range(start: -2m)\n    |> filter(fn: (r) => r._measurement == \"Branch\" and r.unit == \"Watts\")\n    |> last()\n    |> keep(columns: [\"_value\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "thresholds"
          },
