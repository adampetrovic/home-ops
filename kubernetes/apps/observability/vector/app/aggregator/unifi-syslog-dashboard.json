{
  "annotations": { "list": [] },
  "description": "UniFi network device logs via syslog → Vector → Loki",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "WAN & Gateway",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "points",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 10,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "always",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "WAN Down" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "WAN Up" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "WAN Unknown" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "WAN Failover State Changes",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"wan-failover-interfaces.*is down\" [$__auto])",
          "legendFormat": "WAN Down",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"wan-failover-interfaces.*is up\" [$__auto])",
          "legendFormat": "WAN Up",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"wan-failover-interfaces.*is unknown\" [$__auto])",
          "legendFormat": "WAN Unknown",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "WAN Problems & Recovery",
      "description": "WAN failover state changes, IP loss/recovery, DHCP bound/deconfig, dpinger, DNS monitor failures",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=\"cloudkey\"} |~ \"(wan-failover|wan_update_ip|dpinger|could not resolve|dhcp-client.*(bound|deconfig|leasefail)|ubios-udhcpc-decline|linkcheck.*(speedtest|Completed))\" | json | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 14,
      "options": {
        "dedupStrategy": "signature",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "WAN DHCP Lease Activity",
      "description": "eth4 DHCP lease renewals, binds, and offers",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=\"cloudkey\"} |~ \"(dhcp-client.*eth4|udhcpc.*(ACK|NAK|renew|bound|deconfig|lease)|ubios-udhcpc-decline)\" | json | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Firewall",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Blocks",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"DESCR=\" [$__range]))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 20, "x": 4, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Firewall Blocks by Source Zone",
      "description": "br20=IoT, br40=Not, br50=Security, br10=Trusted, br80=Talos",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (in_iface) (count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"DESCR=\" | json | line_format \"{{.message}}\" | pattern `<_>IN=<in_iface> OUT=<_>` [$__auto]))",
          "legendFormat": "{{ in_iface }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Count" }, "properties": [{ "id": "custom.width", "value": 70 }] },
          { "matcher": { "id": "byName", "options": "proto" }, "properties": [{ "id": "custom.width", "value": 55 }] },
          { "matcher": { "id": "byName", "options": "dpt" }, "properties": [{ "id": "custom.width", "value": 65 }] },
          { "matcher": { "id": "byName", "options": "src" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "in_iface" }, "properties": [{ "id": "custom.width", "value": 65 }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "title": "Top Blocked Sources",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(25, sum by (src, dst, proto, dpt, in_iface) (count_over_time({source=\"syslog\", hostname=\"cloudkey\"} |~ \"DESCR=\" | json | line_format \"{{.message}}\" | pattern `<_>IN=<in_iface> OUT=<_> <_>SRC=<src> DST=<dst> <_> PROTO=<proto> <_>DPT=<dpt> <_>` [$__range])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["sum"] } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "desc": true, "field": "Total" }] } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Recent Firewall Blocks",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=\"cloudkey\"} |~ \"DESCR=\" | json | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 102,
      "title": "Clients & WiFi",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 25 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "WiFi Client Connects / Disconnects",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (event) (count_over_time({source=\"syslog\"} |~ \"CEF.*Client\" | json | line_format \"{{.message}}\" | pattern `<_>|<_>|<event>|<_>` [$__auto]))",
          "legendFormat": "{{ event }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 25 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "WiFi Events by AP",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (hostname) (count_over_time({source=\"syslog\", hostname=~\"wifi-.*\"} |~ \"(EVENT_STA_JOIN|EVENT_STA_LEAVE|EVENT_STA_IP)\" [$__auto]))",
          "legendFormat": "{{ hostname }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 31 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Client Roams & Anomalies",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=~\"wifi-.*\"} |~ \"(sta_roam|anomalies|soft failure)\" | json | line_format \"{{.hostname}}: {{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 31 },
      "id": 9,
      "options": {
        "dedupStrategy": "signature",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "DHCP Leases",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=\"cloudkey\"} |~ \"DHCP(ACK|OFFER|DISCOVER|NAK|RELEASE|REQUEST)\" | json | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 103,
      "title": "Switches & Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 39 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Switch Port Link Events",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (hostname) (count_over_time({source=\"syslog\", hostname=~\"switch-.*\"} |~ \"Link (Up|Down)\" [$__auto]))",
          "legendFormat": "{{ hostname }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 39 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Log Volume by Device",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (hostname) (count_over_time({source=\"syslog\", hostname=~\"$hostname\"} [$__auto]))",
          "legendFormat": "{{ hostname }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 104,
      "title": "Log Explorer",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 46 },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "All Syslog",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{source=\"syslog\", hostname=~\"$hostname\"} | json | line_format \"{{.hostname}} {{.appname}}: {{.message}}\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": ["unifi", "syslog", "network"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "label": "Hostname",
        "multi": true,
        "name": "hostname",
        "options": [],
        "query": { "label": "hostname", "stream": "{source=\"syslog\"}", "type": 1 },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
