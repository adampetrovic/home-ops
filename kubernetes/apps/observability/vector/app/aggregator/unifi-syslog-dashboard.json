          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (hostname) (count_over_time({source=\"syslog\", hostname=~\"wifi-.*\"} |~ \"(associated|disassociated|deauthenticated)\" [$__auto]))",
          "legendFormat": "{{ hostname }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
