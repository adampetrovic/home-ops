            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "DHCP Events",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (hostname) (count_over_time({source=\"syslog\", hostname=~\"$hostname\"} |~ \"(dhcp|DHCP|dnsmasq|udhcpc)\" [$__auto]))",
          "legendFormat": "{{ hostname }}",
