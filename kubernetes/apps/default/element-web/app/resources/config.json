{
  "default_server_config": {
    "m.homeserver": {
      "base_url": "https://matrix.${SECRET_PUBLIC_ANON_DOMAIN}",
      "server_name": "${SECRET_PUBLIC_ANON_DOMAIN}"
    }
  },
  "brand": "Chat",
  "default_country_code": "AU",
  "show_labs_settings": true,
  "default_theme": "custom-Chat Dark",
  "branding": {
    "welcome_background_url": "/welcome-bg.svg",
    "auth_header_logo_url": "/logo.svg",
    "auth_footer_links": []
  },
  "room_directory": {
    "servers": ["${SECRET_PUBLIC_ANON_DOMAIN}"]
  },
  "enable_presence_by_hs_url": {
    "https://matrix.${SECRET_PUBLIC_ANON_DOMAIN}": true
  },
  "disable_custom_urls": true,
  "disable_guests": true,
  "disable_login_language_selector": false,
  "disable_3pid_login": true,
  "features": {
    "feature_video_rooms": false,
    "feature_new_room_decoration_ui": true
  },
  "setting_defaults": {
    "breadcrumbs": true,
    "UIFeature.feedback": false,
    "UIFeature.registration": false,
    "UIFeature.passwordReset": false,
    "UIFeature.deactivate": false,
    "UIFeature.thirdPartyId": false,
    "custom_themes": [
      {
        "name": "Chat Dark",
        "is_dark": true,
        "colors": {
          "accent-color": "#e5a820",
          "primary-color": "#e5a820",
          "warning-color": "#ef4444",
          "sidebar-color": "#0c0c0e",
          "roomlist-background-color": "#0a0a0b",
          "roomlist-text-color": "#e5e5e7",
          "roomlist-text-secondary-color": "#9ca3af",
          "roomlist-highlights-color": "#1c1c1f",
          "roomlist-separator-color": "#1c1c1f",
          "timeline-background-color": "#0a0a0b",
          "timeline-text-color": "#e5e5e7",
          "timeline-text-secondary-color": "#9ca3af",
          "timeline-highlights-color": "#16161a",
          "focus-bg-color": "#1c1c1f",
          "togglesw-off-color": "#3f3f46"
        }
      }
    ]
  },
  "jitsi": {
    "preferred_domain": "meet.element.io"
  }
}
