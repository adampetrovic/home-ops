set -u

if [ -z "${KSTACK_ROOT:-}" ]; then
  printf '{"kstack":"1","status":"error","kind":"infra","message":"KSTACK_ROOT not set; run this script via the skill entrypoint."}\n'
  exit 0
fi

# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/response.sh"

if [ -z "${KSTACK_KUBE_CONTEXT:-}" ]; then
  response::infra_error "KSTACK_KUBE_CONTEXT not set; run this script via the skill entrypoint."
  exit 0
fi

main() {
  # Free-text positional args are an agent hint (the user described what they
  # want); the agent reads them, the script ignores them. Only `-`-prefixed
  # tokens are flags, and this skill defines none.
  for arg in "$@"; do
    case "$arg" in
      -*)
        response::user_error "Unknown flag \`$arg\`. Run \`/${KSTACK_SKILL_NAME:-metrics} --help\` for usage."
        exit 0 ;;
    esac
  done

  if ! command -v kubectl >/dev/null 2>&1; then
    response::infra_error "kubectl not found on PATH."
    exit 0
  fi

  local kctx=(--context="$KSTACK_KUBE_CONTEXT")

  # `kubectl top nodes` is the cheapest call that fails fast when metrics.k8s.io
  # isn't registered (or has no data yet).
  local ms_status ms_detail=""
  if kubectl "${kctx[@]}" top nodes >/dev/null 2>&1; then
    ms_status="available"
  else
    ms_status="unavailable"
    ms_detail=" — install with \`kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml\`"
  fi

  local svcs prom_line="not detected"
  if svcs="$(kubectl "${kctx[@]}" get svc --all-namespaces -o json 2>/dev/null)"; then
    local match
    match="$(printf '%s' "$svcs" | jq -r '
      [ .items[]
        | select((.spec.ports // []) | any(.port == 9090))
        | select(.metadata.name | test("prometheus"; "i"))
        | "\(.metadata.namespace)/\(.metadata.name):9090" ]
      | .[0] // empty
    ' 2>/dev/null || true)"
    [ -n "$match" ] && prom_line="$match"
  fi

  local content
  content="Detected metrics sources for context \`$KSTACK_KUBE_CONTEXT\`:"
  content+=$'\n'"- metrics-server: ${ms_status}${ms_detail}"
  content+=$'\n'"- prometheus: ${prom_line}"

  response::ok_agent "$content"
  exit 0
}

main "$@"
