set -u

# shellcheck source=../../../../lib/response.sh
. "$KSTACK_ROOT/lib/response.sh"
# shellcheck source=../../../../lib/hash.sh
. "$KSTACK_ROOT/lib/hash.sh"

forget_one() {
  local ctx="$1"
  local sha
  sha="$(hash::short_sha "$ctx")"

  local kube_cache_dir="$KSTACK_ROOT/cache/kube/$sha"
  local state_dir="$KSTACK_ROOT/state/$sha"

  local cleared="" nothing=1
  if [ -d "$kube_cache_dir" ]; then
    rm -rf "$kube_cache_dir"
    cleared="${cleared}  cache  ($kube_cache_dir)\n"
    nothing=0
  fi
  if [ -d "$state_dir" ]; then
    rm -rf "$state_dir"
    cleared="${cleared}  state  ($state_dir)\n"
    nothing=0
  fi

  if [ "$nothing" = 1 ]; then
    printf 'Nothing to forget for context `%s` — no local state found.\n' "$ctx"
  else
    printf 'Forgot local state for context `%s`:\n%b' "$ctx" "$cleared"
  fi
}

forget_all() {
  local kube_cache_root="$KSTACK_ROOT/cache/kube"
  local state_root="$KSTACK_ROOT/state"

  local nothing=1
  if [ -d "$kube_cache_root" ]; then
    local d
    for d in "$kube_cache_root"/*/; do
      [ -d "$d" ] && rm -rf "$d" && nothing=0
    done
  fi
  if [ -d "$state_root" ]; then
    local d
    for d in "$state_root"/*/; do
      [ -d "$d" ] && rm -rf "$d" && nothing=0
    done
  fi

  if [ "$nothing" = 1 ]; then
    printf 'Nothing to forget — no local state found for any context.\n'
  else
    printf 'Forgot local state for all contexts.\n'
  fi
}

main() {
  local all=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --all) all=1; shift ;;
      *) response::user_error "Unknown flag \`$1\`. Run \`/${KSTACK_SKILL_NAME:-forget} --help\` for usage."
         exit 0 ;;
    esac
  done

  local msg
  if [ "$all" = 1 ]; then
    msg="$(forget_all)"
  else
    msg="$(forget_one "$KSTACK_KUBE_CONTEXT")"
  fi

  response::ok_verbatim "$msg"
}

main "$@"
