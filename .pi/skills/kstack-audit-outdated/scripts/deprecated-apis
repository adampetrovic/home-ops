set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

if [ -z "${KSTACK_ROOT:-}" ]; then
  printf '{"kstack":"1","status":"error","kind":"infra","message":"KSTACK_ROOT not set; run this script via the skill entrypoint."}\n'
  exit 0
fi

# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/response.sh"
# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/kube-cache.sh"
# shellcheck source=/dev/null
. "$KSTACK_ROOT/lib/state.sh"
# shellcheck source=lib/deprecated-apis.sh
. "$SCRIPT_DIR/lib/deprecated-apis.sh"

if [ -z "${KSTACK_KUBE_CONTEXT:-}" ]; then
  response::infra_error "KSTACK_KUBE_CONTEXT not set; run this script via the skill entrypoint."
  exit 0
fi

_STATE_BACKEND_KEY="audit-outdated/deprecated-apis-backend"

backend_tool_available() {
  case "$1" in
    pluto)  command -v pluto  >/dev/null 2>&1 ;;
    kubent) command -v kubent >/dev/null 2>&1 ;;
    web)    command -v curl   >/dev/null 2>&1 ;;
    skip)   return 0 ;;
    *) return 1 ;;
  esac
}

main() {
  local ttl="15m" refresh="false" backend="" scope="global"
  while [ $# -gt 0 ]; do
    case "$1" in
      --refresh) refresh="true"; shift ;;
      --ttl=*) ttl="${1#--ttl=}"; shift ;;
      --ttl)
        if [ $# -lt 2 ]; then
          response::user_error "Flag --ttl requires a value."
          exit 0
        fi
        ttl="$2"; shift 2 ;;
      --backend=*) backend="${1#--backend=}"; shift ;;
      --backend)
        if [ $# -lt 2 ]; then
          response::user_error "Flag --backend requires a value (pluto|kubent|web|skip)."
          exit 0
        fi
        backend="$2"; shift 2 ;;
      --scope=*) scope="${1#--scope=}"; shift ;;
      --scope)
        if [ $# -lt 2 ]; then
          response::user_error "Flag --scope requires a value (global|context)."
          exit 0
        fi
        scope="$2"; shift 2 ;;
      *)
        response::user_error "Unknown flag \`$1\`. Run \`/${KSTACK_SKILL_NAME:-audit-outdated} --help\` for usage."
        exit 0 ;;
    esac
  done

  if [ -z "$backend" ]; then
    response::user_error "Flag --backend is required (pluto|kubent|web|skip)."
    exit 0
  fi

  case "$backend" in
    pluto|kubent|web|skip) ;;
    *)
      response::user_error "Invalid --backend value \`$backend\`. Use pluto, kubent, web, or skip."
      exit 0 ;;
  esac

  case "$scope" in
    global|context) ;;
    *)
      response::user_error "Invalid --scope value \`$scope\`. Use global or context."
      exit 0 ;;
  esac

  if [ "$backend" != "skip" ] && ! backend_tool_available "$backend"; then
    local tool="$backend"
    [ "$backend" = "web" ] && tool="curl"
    response::user_error "Backend \`$backend\` is not available: \`$tool\` not found on PATH."
    exit 0
  fi

  # Persist the user's choice. Context scope requires init_context; global
  # scope only needs init.
  if [ "$scope" = "context" ]; then
    if ! state::init_context; then
      response::"${STATE_ERROR_KIND}_error" "$STATE_ERROR"
      exit 0
    fi
  else
    if ! state::init; then
      response::"${STATE_ERROR_KIND}_error" "$STATE_ERROR"
      exit 0
    fi
  fi

  if ! state::set "$scope" "$_STATE_BACKEND_KEY" "$backend"; then
    response::infra_error "Unable to persist backend preference."
    exit 0
  fi

  # skip backend: no cluster calls, just a short confirmation envelope.
  if [ "$backend" = "skip" ]; then
    local agent_ctx
    agent_ctx="$(printf '{"deprecated_apis":{"status":"skipped","backend":"skip","scope":"%s"}}' "$scope")"
    response::ok_verbatim "Deprecated APIs:"$'\n'"  Skipped. Preference saved (scope: $scope)." "$agent_ctx"
    exit 0
  fi

  local init_args=(--ttl="$ttl")
  [ "$refresh" = "true" ] && init_args+=(--refresh)
  if ! kube_cache::init "${init_args[@]}"; then
    case "$KUBE_CACHE_ERROR_KIND" in
      user) response::user_error "$KUBE_CACHE_ERROR" ;;
      *)    response::infra_error "$KUBE_CACHE_ERROR" ;;
    esac
    exit 0
  fi

  if ! kube_cache::ensure_version; then
    # shellcheck disable=SC2016
    response::infra_error "$(printf 'Unable to fetch cluster version for context `%s`.' "$KUBE_CACHE_CONTEXT")"
    exit 0
  fi

  local server_version server_minor
  server_version="$(jq -r '.serverVersion.gitVersion' "$KUBE_CACHE_DIR/cluster.json")" || {
    response::infra_error "Unable to parse cluster version from cache."
    exit 0
  }
  local _tmp="${server_version#v}"; server_minor="${_tmp%.*}"

  local err_tmp block_file
  err_tmp="$(mktemp 2>/dev/null || echo "/tmp/kstack-da-err-$$")"
  block_file="$err_tmp.block"
  # shellcheck disable=SC2064
  trap "rm -f '$err_tmp' '$block_file'" EXIT

  if ! deprecated_apis::render_backend "$backend" "$server_minor" > "$block_file" 2>"$err_tmp"; then
    response::infra_error "$(cat "$err_tmp")"
    exit 0
  fi

  local dir_esc agent_ctx
  dir_esc="$(printf '%s' "$KUBE_CACHE_DIR" | response::_escape)"
  agent_ctx="$(printf '{"cache_dir":"%s","deprecated_apis":{"status":"ok","backend":"%s","scope":"%s"}}' \
    "$dir_esc" "$backend" "$scope")"

  if [ "$DEPRECATED_APIS_AGENT_NEEDED" = "true" ]; then
    local agent_content
    agent_content="## Deprecated API Detection (via kubernetes.io)"$'\n\n'
    agent_content+="Cross-reference the cluster's active API versions against the deprecation guide below."$'\n'
    agent_content+="Report any active API versions the guide marks as removed or deprecated at cluster version $server_version."$'\n\n'
    agent_content+="### Active API versions on this cluster"$'\n\n'
    agent_content+='```'$'\n'"$DEPRECATED_APIS_ACTIVE_VERSIONS"$'\n''```'$'\n\n'
    agent_content+="### Kubernetes Deprecation Guide (raw)"$'\n\n'
    agent_content+="$DEPRECATED_APIS_RAW_PAGE"
    response::ok_agent "$agent_content" "$agent_ctx"
    exit 0
  fi

  local content
  content="$(cat "$block_file")"
  response::ok_verbatim "Deprecated APIs:"$'\n'"$content" "$agent_ctx"
  exit 0
}

main "$@"
